# =============================================================
# TecnoMarket — Configuración del sistema de respaldos
# Copia este archivo a "config.env" y ajusta los valores.
# config.env está en .gitignore para no subir credenciales.
# =============================================================

# --- Base de datos ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=tecnomarket_db

# --- Retención ---
RETENTION_DAILY_DAYS=30       # Días que se conservan los respaldos diarios
RETENTION_WEEKLY_WEEKS=12     # Semanas que se conservan los semanales (~3 meses)

# --- Rutas de binarios (dejar vacío para autodetección) ---
# Si mysqldump no está en tu PATH, pon la ruta completa aquí.
# Ejemplos:
#   Linux/macOS:  /usr/bin/mysqldump
#   XAMPP Win:    C:\xampp\mysql\bin\mysqldump.exe
#   WAMP Win:     C:\wamp64\bin\mysql\mysql8.0.27\bin\mysqldump.exe
MYSQLDUMP_PATH=
MYSQL_PATH=

# --- Directorio base de respaldos ---
# Dejar vacío para usar la carpeta del script como base.
# Ejemplo absoluto: /var/backups/tecnomarket  o  D:\Backups\tecnomarket
BACKUP_BASE=

# --- Notificaciones por email (opcional, solo Linux/macOS con mailutils) ---
NOTIFY_EMAIL=
